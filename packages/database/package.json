{
  "name": "@pwnable/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate": "sh -c 'set -a; . ../../.env; set +a; prisma migrate dev \"$@\"' --",
    "push": "sh -c 'set -a; . ../../.env; set +a; prisma db push \"$@\"' --",
    "seed": "sh -c 'set -a; . ../../.env; set +a; tsx prisma/seed.ts' --",
    "studio": "sh -c 'set -a; . ../../.env; set +a; prisma studio \"$@\"' --"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2"
  },
  "devDependencies": {
    "prisma": "^6.8.2",
    "tsx": "^4.19.2",
    "argon2": "^0.41.1",
    "@types/node": "^22.10.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
